{
  "name": "dice_grid_hunt",
  "display_name": "九宫格骰子竞猜",
  "description": "发送九宫格骰子图片，公布唯一目标点数，群内抢答格子赢奖励",
  "author": "Anoyou",
  "version": "1.0.3",
  "entry": "plugin.py",
  "permissions": ["send_message", "edit_message", "read_chat", "send_file"],
  "min_telebot_version": "0.10.0",
  "cleanup_mode": "resource",
  "commands": ["dicegrid", "九宫格", "骰子竞猜"],
  "tags": ["game", "dice", "quiz"],
  "config_schema": {
    "type": "object",
    "x-ui-mode": "schema",
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "title": "触发指令名",
        "default": "dicegrid",
        "minLength": 1,
        "maxLength": 32,
        "pattern": "^\\S+$"
      },
      "timeout": {
        "type": "integer",
        "title": "答题限时（秒）",
        "default": 90,
        "minimum": 10,
        "maximum": 86400
      },
      "auto_next": {
        "type": "boolean",
        "title": "结束后自动下一轮",
        "default": false
      },
      "next_delay": {
        "type": "integer",
        "title": "下一轮延迟（秒）",
        "default": 3,
        "minimum": 1,
        "maximum": 60
      }
    },
    "required": ["command", "timeout", "auto_next", "next_delay"]
  },
  "license": "MIT"
}
