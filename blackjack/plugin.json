{
  "name": "blackjack",
  "display_name": "21点",
  "description": "经典21点纸牌游戏，群内庄家模式，支持要牌/停牌/加倍",
  "author": "Anoyou",
  "version": "1.0.1",
  "entry": "plugin.py",
  "permissions": ["send_message", "edit_message", "read_chat", "delete_message"],
  "min_telebot_version": "0.10.0",
  "cleanup_mode": "resource",
  "commands": ["bj", "21点", "blackjack"],
  "tags": ["game", "card", "casino"],
  "config_schema": {
    "type": "object",
    "x-ui-mode": "schema",
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "title": "触发指令名",
        "default": "bj",
        "minLength": 1,
        "maxLength": 32,
        "pattern": "^\\S+$"
      },
      "timeout": {
        "type": "integer",
        "title": "牌局限时（秒）",
        "default": 120,
        "minimum": 10,
        "maximum": 86400
      }
    },
    "required": ["command", "timeout"]
  },
  "license": "MIT"
}
