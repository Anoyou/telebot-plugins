{
  "name": "gi2-byRBQ",
  "display_name": "gi2-byRBQ",
  "description": "图片生成与改图插件，支持直接生图、回复图片改图、GI2 结果图原地继续编辑，并对高风险原图断流做诊断提示",
  "author": "RBQ (migrated from zhiluop/pagermaid_plugins)",
  "version": "1.0.3",
  "entry": "plugin.py",
  "min_telebot_version": "0.10.2",
  "commands": [
    "gi2"
  ],
  "cleanup_mode": "resource",
  "tags": [
    "migrated",
    "pagermaid",
    "byRBQ"
  ],
  "permissions": [
    "send_message",
    "edit_message",
    "read_chat"
  ],
  "config_schema": {
    "type": "object",
    "x-ui-mode": "single",
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "title": "触发指令名",
        "default": "gi2",
        "minLength": 1,
        "maxLength": 32,
        "pattern": "^\\S+$"
      },
      "enabled": {
        "type": "boolean",
        "title": "是否启用",
        "default": true
      }
    },
    "required": [
      "command",
      "enabled"
    ]
  },
  "category": "utility",
  "interaction_entries": [],
  "min_telepilot_version": "0.30.4"
}
