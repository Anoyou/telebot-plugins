{
  "name": "dice_battle",
  "display_name": "骰子比大小",
  "description": "群内骰子对战，两人各掷骰子比点数，支持下注",
  "author": "Anoyou",
  "version": "1.0.2",
  "entry": "plugin.py",
  "permissions": [
    "send_message",
    "edit_message",
    "read_chat"
  ],
  "min_telebot_version": "0.10.0",
  "cleanup_mode": "resource",
  "commands": [
    "dice",
    "骰子",
    "pk"
  ],
  "tags": [
    "game",
    "dice",
    "casino"
  ],
  "config_schema": {
    "type": "object",
    "x-ui-mode": "schema",
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "title": "触发指令名",
        "default": "dice",
        "minLength": 1,
        "maxLength": 32,
        "pattern": "^\\S+$"
      },
      "timeout": {
        "type": "integer",
        "title": "邀请限时（秒）",
        "default": 60,
        "minimum": 10,
        "maximum": 86400
      }
    },
    "required": [
      "command",
      "timeout"
    ]
  },
  "license": "MIT",
  "category": "interactive",
  "interaction_entries": [
    {
      "key": "start_dice_battle",
      "title": "开始骰子对战",
      "description": "由交互 Bot 在群内发起一局骰子比大小。",
      "session_scope": "chat",
      "input_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "timeout": {
            "type": "integer",
            "title": "邀请限时（秒）",
            "default": 60,
            "minimum": 10,
            "maximum": 86400
          }
        }
      }
    }
  ]
}
