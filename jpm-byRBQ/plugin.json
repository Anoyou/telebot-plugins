{
  "name": "jpm-byRBQ",
  "display_name": "jpm-byRBQ",
  "description": "关键词触发回复插件，支持多关键词、频率限制、锚点消息系统",
  "author": "RBQ (migrated from zhiluop/pagermaid_plugins)",
  "version": "1.0.5",
  "entry": "plugin.py",
  "min_telebot_version": "0.10.2",
  "commands": [
    "jpm"
  ],
  "cleanup_mode": "resource",
  "tags": [
    "migrated",
    "pagermaid",
    "byRBQ"
  ],
  "permissions": [
    "send_message",
    "edit_message",
    "read_chat"
  ],
  "config_schema": {
    "type": "object",
    "x-ui-mode": "single",
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "title": "触发指令名",
        "default": "jpm",
        "minLength": 1,
        "maxLength": 32,
        "pattern": "^\\S+$"
      },
      "enabled": {
        "type": "boolean",
        "title": "是否启用",
        "default": true
      }
    },
    "required": [
      "command",
      "enabled"
    ],
    "x-usage-guide": "发送 {prefix}{command} 按原 Pagermaid 方式触发贴纸自动回复能力；可在配置页调整触发指令名和启用状态。"
  },
  "category": "automation",
  "interaction_entries": [],
  "min_telepilot_version": "0.33.0"
}
