{
  "name": "chatter_challenge",
  "display_name": "话痨挑战",
  "description": "设定聊天规则，违反者自动扣分，全程被动监听",
  "author": "Anoyou",
  "version": "1.0.4",
  "entry": "plugin.py",
  "permissions": [
    "send_message",
    "edit_message",
    "read_chat"
  ],
  "min_telebot_version": "0.10.0",
  "cleanup_mode": "resource",
  "commands": [
    "chat",
    "话痨",
    "挑战"
  ],
  "tags": [
    "game",
    "social",
    "monitor"
  ],
  "config_schema": {
    "type": "object",
    "x-ui-mode": "single",
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "title": "触发指令名",
        "default": "chat",
        "minLength": 1,
        "maxLength": 32,
        "pattern": "^\\S+$"
      }
    },
    "required": [
      "command"
    ]
  },
  "license": "MIT",
  "category": "automation",
  "interaction_entries": [],
  "min_telepilot_version": "0.30.4"
}
