{
  "name": "pixivshow-byRBQ",
  "display_name": "pixivshow-byRBQ",
  "description": "Pixiv 美少女推图插件，支持普通图与 R18 图推送，R18 自动添加 Telegram 遮罩，可指定单次推送数量",
  "author": "RBQ (migrated from zhiluop/pagermaid_plugins)",
  "version": "1.0.5",
  "entry": "plugin.py",
  "min_telebot_version": "0.10.2",
  "commands": [
    "pixiv",
    "pixivr18"
  ],
  "cleanup_mode": "resource",
  "tags": [
    "migrated",
    "pagermaid",
    "byRBQ"
  ],
  "permissions": [
    "send_message",
    "edit_message",
    "read_chat"
  ],
  "config_schema": {
    "type": "object",
    "x-ui-mode": "single",
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "title": "触发指令名",
        "default": "pixiv",
        "minLength": 1,
        "maxLength": 32,
        "pattern": "^\\S+$"
      },
      "enabled": {
        "type": "boolean",
        "title": "是否启用",
        "default": true
      }
    },
    "required": [
      "command",
      "enabled"
    ],
    "x-usage-guide": "发送 {prefix}{command} 按原 Pagermaid 方式拉取 Pixiv 图片或多图结果；可在配置页调整触发指令名和启用状态，R18 内容按原插件规则处理。"
  },
  "category": "utility",
  "interaction_entries": [],
  "min_telepilot_version": "0.33.0"
}
