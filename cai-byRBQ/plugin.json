{
  "name": "cai-byRBQ",
  "display_name": "cai-byRBQ",
  "description": "# CAI - 自动点踩插件 自动点踩插件，支持多目标配置、冷却时间限制、标准表情和自定义表情。支...",
  "author": "RBQ (migrated from zhiluop/pagermaid_plugins)",
  "version": "1.0.5",
  "entry": "plugin.py",
  "min_telebot_version": "0.10.2",
  "commands": [
    "cai"
  ],
  "cleanup_mode": "resource",
  "tags": [
    "migrated",
    "pagermaid",
    "byRBQ"
  ],
  "permissions": [
    "send_message",
    "edit_message",
    "read_chat"
  ],
  "config_schema": {
    "type": "object",
    "x-ui-mode": "single",
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "title": "触发指令名",
        "default": "cai",
        "minLength": 1,
        "maxLength": 32,
        "pattern": "^\\S+$"
      },
      "enabled": {
        "type": "boolean",
        "title": "是否启用",
        "default": true
      }
    },
    "required": [
      "command",
      "enabled"
    ],
    "x-usage-guide": "发送 {prefix}{command} 触发原 Pagermaid 自动点踩相关能力；可在配置页调整触发指令名和启用状态。命令只填写本体，不要包含系统前缀。"
  },
  "category": "automation",
  "interaction_entries": [],
  "min_telepilot_version": "0.33.0"
}
