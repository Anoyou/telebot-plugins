{
  "name": "jpmai-byRBQ",
  "display_name": "jpmai-byRBQ",
  "description": "AI 生成艳情文案插件，支持完整 chat/completions URL 兼容、非标准响应文本提取和连通性测试",
  "author": "RBQ (migrated from zhiluop/pagermaid_plugins)",
  "version": "1.0.4",
  "entry": "plugin.py",
  "min_telebot_version": "0.10.2",
  "commands": [
    "jpmai"
  ],
  "cleanup_mode": "resource",
  "tags": [
    "migrated",
    "pagermaid",
    "byRBQ"
  ],
  "permissions": [
    "send_message",
    "edit_message",
    "read_chat"
  ],
  "config_schema": {
    "type": "object",
    "x-ui-mode": "single",
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "title": "触发指令名",
        "default": "jpmai",
        "minLength": 1,
        "maxLength": 32,
        "pattern": "^\\S+$"
      },
      "enabled": {
        "type": "boolean",
        "title": "是否启用",
        "default": true
      }
    },
    "required": [
      "command",
      "enabled"
    ]
  },
  "category": "utility",
  "interaction_entries": [],
  "min_telepilot_version": "0.33.0"
}
